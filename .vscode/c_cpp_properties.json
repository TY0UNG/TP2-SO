{
    "configurations": [
        {
            "name": "Linux",
            "includePath": [
                "${workspaceFolder}/Kernel/include",
                "${workspaceFolder}/Kernel/resources/fonts",
                "${workspaceFolder}/Kernel",
                "${workspaceFolder}/Userland/**",
                "/usr/lib/gcc/x86_64-linux-gnu/13/include"
            ],
            "defines": [
                "MM_OWN"
            ],
            "compilerPath": "/usr/bin/x86_64-linux-gnu-gcc",
            "compilerArgs": [
                "-ffreestanding",
                "-fno-builtin",
                "-m64"
            ],
            "cStandard": "c99",
            "cppStandard": "c++98",
            "intelliSenseMode": "linux-gcc-x64"
        }
    ],
    "version": 4
}
